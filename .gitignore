# NAQ private R&D — ground-truth votes + algorithm refinement (potential paper).
# Tool + data stay local; do not commit.
naq_lab/

# Windows: bash treats `nul` as a regular filename, so `cmd 2>nul`
# from a bash shell on Windows leaves a literal file behind.
nul
NUL

# scoring/: keep scores.csv (the public hand-off) committed, but never the large
# manually-fetched SIM checkpoint or the cloned third-party SV code.
scoring/checkpoints/*.pth
scoring/checkpoints/*.pt
scoring/thirdparty/

