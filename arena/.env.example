# Local Turso creds for `python -m arena.export_votes` (vote backup / NAQ pulls).
#
# Copy this file to arena/.env and fill in YOUR values from the Turso dashboard
# (the tts-arena DB URL + an auth token) or HF Space -> Settings -> Secrets.
#
#   arena/.env is gitignored -- never commit it.
#   The live Space does NOT read this file; it uses its own HF Space secrets.
TURSO_URL=libsql://your-db-host.turso.io
TURSO_TOKEN=your-turso-auth-token
